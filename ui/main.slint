import { Button, VerticalBox, LineEdit } from "std-widgets.slint";

export component MainWindow inherits Window {
    // Данные системы
    in-out property <string> current-time: "12:00";
    // Состояния: "lock", "home", "search", "files", "music", "phone"
    in-out property <string> active-screen: "lock"; 
    in-out property <string> calc-display: "0";


component CalcButton {
    in property <string> text;
    in property <color> bg-color: #333;
    callback clicked;
    Rectangle {
        background: touch.pressed ? #555 : bg-color;
        border-radius: 10px;
        Text { text: root.text; font-size: 24px; color: white; }
        touch := TouchArea { clicked => { root.clicked(); } }
    }
}

    // Параметры окна
    width: 360px;
    height: 640px;
    background: black;

    // Обработчики для Rust
    callback search-pressed(string);
    callback calc-button-pressed(string);

    // 1. ФОНОВЫЕ ОБОИ (на все экраны)
    Image {
        source: @image-url("img/background.png");
        width: 100%;
        height: 100%;
        image-fit: cover;
    }

    // --- ЭКРАН БЛОКИРОВКИ ---
    if (active-screen == "lock") : TouchArea {
        clicked => { active-screen = "home"; }
        VerticalBox {
            alignment: center;
            Text {
                text: root.current-time;
                font-size: 60px;
                color: white;
                font-weight: 700;
            }
            Text {
                text: "Нажмите, чтобы разблокировать";
                color: #ccc;
                font-size: 14px;
                horizontal-alignment: center;
            }
        }
    }

    // --- ОСНОВНАЯ ОБОЛОЧКА СИСТЕМЫ (после разблокировки) ---
    if (active-screen != "lock") : VerticalBox {
        padding: 0;
        spacing: 0;

        // ВЕРХНЯЯ ЧАСТЬ: Контент приложений
        Rectangle {
            vertical-stretch: 1; // Занимает всё свободное место до дока/панели
            
            // Рабочий стол
            if (active-screen == "home") : VerticalBox {
                padding: 20px;
                alignment: start;
                Text {
                    text: root.current-time;
                    font-size: 45px;
                    color: white;
                    horizontal-alignment: center;
                    font-weight: 500;
                }
            }

            // Поисковик
            if (active-screen == "search") : VerticalBox {
                padding: 30px;
                spacing: 20px;
                alignment: start;
                Text {
                    text: "Mew Search";
                    font-size: 28px;
                    color: #ff0055;
                    horizontal-alignment: center;
                    font-weight: 800;
                }
                search_input := LineEdit {
                    placeholder-text: "Поиск в Kayoosh...";
                    height: 45px;
                }
                Button {
                    text: "Найти";
                    primary: true;
                    height: 40px;
                    clicked => { root.search-pressed(search_input.text); }
                }
            }

            // Заглушки для остальных приложений
            if (active-screen == "calculator") : VerticalBox {
                padding: 20px;
                spacing: 15px;
                
                // Дисплей
                Rectangle {
                    height: 80px;
                    background: #1a1a1a;
                    border-radius: 10px;
                    Text {
                        text: root.calc-display;
                        font-size: 32px;
                        color: white;
                        horizontal-alignment: right;
                        vertical-alignment: center;
                        padding-right: 15px;
                    }
                }

                // Сетка кнопок
                GridLayout {
                    spacing: 10px;
                    Row {
                        CalcButton { text: "C"; bg-color: #555; clicked => { root.calc-button-pressed("C") } }
                        CalcButton { text: "÷"; bg-color: #f39c12; clicked => { root.calc-button-pressed("/") } }
                    }
                    Row {
                        CalcButton { text: "7"; clicked => { root.calc-button-pressed("7") } }
                        CalcButton { text: "8"; clicked => { root.calc-button-pressed("8") } }
                        CalcButton { text: "9"; clicked => { root.calc-button-pressed("9") } }
                        CalcButton { text: "×"; bg-color: #f39c12; clicked => { root.calc-button-pressed("*") } }
                    }
                    Row {
                        CalcButton { text: "4"; clicked => { root.calc-button-pressed("4") } }
                        CalcButton { text: "5"; clicked => { root.calc-button-pressed("5") } }
                        CalcButton { text: "6"; clicked => { root.calc-button-pressed("6") } }
                        CalcButton { text: "−"; bg-color: #f39c12; clicked => { root.calc-button-pressed("-") } }
                    }
                    Row {
                        CalcButton { text: "1"; clicked => { root.calc-button-pressed("1") } }
                        CalcButton { text: "2"; clicked => { root.calc-button-pressed("2") } }
                        CalcButton { text: "3"; clicked => { root.calc-button-pressed("3") } }
                        CalcButton { text: "+"; bg-color: #f39c12; clicked => { root.calc-button-pressed("+") } }
                    }
                    Row {
                        CalcButton { text: "0"; colspan: 2; clicked => { root.calc-button-pressed("0") } }
                        CalcButton { text: "="; bg-color: #f39c12; clicked => { root.calc-button-pressed("=") } }
                    }
                }
            }
            if (active-screen == "music") : VerticalBox { alignment: center; Text { text: "Музыкальный плеер"; color: white; font-size: 20px; } }
            if (active-screen == "phone") : VerticalBox { alignment: center; Text { text: "Телефон"; color: white; font-size: 20px; } }
        }

        // НИЖНИЙ ДОК (Иконки быстрого доступа) - виден только на Home
        if (active-screen == "home") : Rectangle {
            height: 90px;
            background: rgba(0, 0, 0, 0.4);
            HorizontalLayout {
                padding: 10px;
                spacing: 15px;
                alignment: center;
                
                // Иконка Поиска
                Rectangle {
                    width: 65px; height: 65px;
                    Image { source: @image-url("img/icons/search.png"); width: 50px; }
                    TouchArea { clicked => { active-screen = "search"; } }
                }
                // Иконка Файлов
                Rectangle {
                    width: 65px; height: 65px;
                    Image { source: @image-url("img/icons/file.png"); width: 50px; }
                    TouchArea { clicked => { active-screen = "files"; } }
                }
                // Иконка Музыки
                Rectangle {
                    width: 65px; height: 65px;
                    Image { source: @image-url("img/icons/music.png"); width: 50px; }
                    TouchArea { clicked => { active-screen = "music"; } }
                }
                // Иконка Телефона
                Rectangle {
                    width: 65px; height: 65px;
                    Image { source: @image-url("img/icons/phone.png"); width: 50px; }
                    TouchArea { clicked => { active-screen = "phone"; } }
                }
            }
        }

        // СИСТЕМНАЯ ПАНЕЛЬ НАВИГАЦИИ (Назад, Домой, Окна)
        Rectangle {
            height: 50px;
            background: #000;
            HorizontalLayout {
                padding: 5px;
                alignment: space-around;
                
                // Кнопка "Назад"
                Text { 
                    text: "◁"; color: white; font-size: 24px; 
                    TouchArea { clicked => { active-screen = "home"; } } 
                }
                // Кнопка "Домой"
                Text { 
                    text: "○"; color: white; font-size: 24px; 
                    TouchArea { clicked => { active-screen = "home"; } } 
                }
                // Кнопка "Окна"
                Text { 
                    text: "☐"; color: white; font-size: 24px; 
                }
            }
        }
    }
}