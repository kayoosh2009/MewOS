import { Button, VerticalBox, LineEdit } from "std-widgets.slint";

export component MainWindow inherits Window {
    in-out property <string> current-time: "12:00";
    // Состояния: "lock", "home", "search", "files", "music", "phone"
    in-out property <string> active-screen: "lock"; 

    width: 360px;
    height: 640px;
    background: black;

    // Фоновое изображение (на весь экран)
    Image {
        source: @image-url("img/background.png");
        width: 100%;
        height: 100%;
        image-fit: cover;
    }

    // --- ЭКРАН БЛОКИРОВКИ ---
    if (active-screen == "lock") : TouchArea {
        clicked => { active-screen = "home"; }
        VerticalBox {
            alignment: center;
            Text {
                text: root.current-time;
                font-size: 60px;
                color: white;
                font-weight: 700;
            }
            Text {
                text: "Нажмите, чтобы разблокировать";
                color: #ccc;
                font-size: 14px;
                horizontal-alignment: center;
            }
        }
    }

    // --- ОСНОВНОЙ КОНТЕНТ (Главный экран и приложения) ---
    if (active-screen != "lock") : VerticalBox {
        padding: 0;
        spacing: 0;

        // Рабочая область
        Rectangle {
            VerticalBox {
                padding: 20px;
                if (active-screen == "home") : VerticalBox {
                    alignment: start;
                    Text {
                        text: root.current-time;
                        font-size: 40px;
                        color: white;
                        horizontal-alignment: center;
                    }
                }
                if (active-screen == "search") : Text { text: "Поиск..."; color: white; }
                if (active-screen == "files") : Text { text: "Файлы"; color: white; }
                if (active-screen == "music") : Text { text: "Музыка"; color: white; }
                if (active-screen == "phone") : Text { text: "Телефон"; color: white; }
            }
        }

        // --- НИЖНИЙ ДОК (Иконки приложений) ---
        if (active-screen == "home") : Rectangle {
            height: 80px;
            background: rgba(0, 0, 0, 0.5);
            HorizontalLayout {
                padding: 10px;
                spacing: 15px;
                alignment: center;
                
                // Поиск
                Rectangle {
                    width: 60px; height: 60px;
                    Image { source: @image-url("img/icons/search.png"); width: 45px; }
                    TouchArea { clicked => { active-screen = "search"; } }
                }
                // Файлы
                Rectangle {
                    width: 60px; height: 60px;
                    Image { source: @image-url("img/icons/file.png"); width: 45px; }
                    TouchArea { clicked => { active-screen = "files"; } }
                }
                // Музыка
                Rectangle {
                    width: 60px; height: 60px;
                    Image { source: @image-url("img/icons/music.png"); width: 45px; }
                    TouchArea { clicked => { active-screen = "music"; } }
                }
                // Телефон
                Rectangle {
                    width: 60px; height: 60px;
                    Image { source: @image-url("img/icons/phone.png"); width: 45px; }
                    TouchArea { clicked => { active-screen = "phone"; } }
                }
            }
        }

        // --- ПАНЕЛЬ НАВИГАЦИИ (Назад, Домой, Окна) ---
        Rectangle {
            height: 50px;
            background: black;
            HorizontalLayout {
                padding: 5px;
                alignment: space-around;
                
                // Назад (просто возвращает домой в этой версии)
                Text { text: "◁"; color: white; font-size: 24px; TouchArea { clicked => { active-screen = "home"; } } }
                // Домой
                Text { text: "○"; color: white; font-size: 24px; TouchArea { clicked => { active-screen = "home"; } } }
                // Окна
                Text { text: "☐"; color: white; font-size: 24px; }
            }
        }
    }
}